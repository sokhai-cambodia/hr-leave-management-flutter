# Copy this file to .env and adjust for your machine.
# .env is gitignored — every developer keeps their own.
# Not used for secrets: this only holds the backend base URL, which is not sensitive.
#
# Precedence: --dart-define=API_BASE_URL=<url> always wins over .env (used for CI/other builds);
# .env is read if no dart-define was passed; the hardcoded default in lib/core/constants/env.dart
# is the last resort if neither is present.

# Android emulator (default) — 10.0.2.2 is the emulator's host-loopback address
API_BASE_URL=http://10.0.2.2:8000/api/v1

# Windows/desktop dev, or a physical device on the same network — examples:
# API_BASE_URL=http://localhost:8000/api/v1
